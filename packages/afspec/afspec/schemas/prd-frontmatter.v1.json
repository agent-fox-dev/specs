{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-fox.dev/schemas/prd-frontmatter.v1.json",
  "title": "PRD Frontmatter",
  "description": "Schema for the YAML frontmatter block in prd.md",
  "type": "object",
  "properties": {
    "spec_id": {
      "type": "string",
      "minLength": 1
    },
    "spec_name": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "sealed", "superseded", "archived"]
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "intent_hash": {
      "type": ["string", "null"]
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    }
  },
  "required": ["spec_id", "spec_name", "title", "status", "created_at", "updated_at", "schema_version"],
  "additionalProperties": false
}

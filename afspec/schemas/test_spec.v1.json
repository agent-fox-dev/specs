{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TestSpec",
  "description": "Schema for test_spec.json spec artifact (v1)",
  "type": "object",
  "required": [
    "spec_id",
    "spec_name",
    "schema_version",
    "test_cases",
    "property_tests",
    "edge_case_tests",
    "smoke_tests",
    "coverage"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {},
    "spec_id": {
      "type": "string",
      "minLength": 1
    },
    "spec_name": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "test_cases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TestCase"
      }
    },
    "property_tests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/PropertyTest"
      }
    },
    "edge_case_tests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/EdgeCaseTest"
      }
    },
    "smoke_tests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/SmokeTest"
      }
    },
    "coverage": {
      "$ref": "#/$defs/Coverage"
    },
    "$comment": {
      "type": "string"
    }
  },
  "$defs": {
    "TestCase": {
      "type": "object",
      "required": [
        "id",
        "requirement_id",
        "kind",
        "description",
        "preconditions",
        "input",
        "expected",
        "assertion_pseudocode"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "requirement_id": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "preconditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "input": {
          "type": "object"
        },
        "expected": {
          "type": "object"
        },
        "assertion_pseudocode": {
          "type": "string"
        }
      }
    },
    "PropertyTest": {
      "type": "object",
      "required": [
        "id",
        "property_id",
        "validates",
        "description",
        "for_any_strategy",
        "invariant_check"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "property_id": {
          "type": "string"
        },
        "validates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "description": {
          "type": "string"
        },
        "for_any_strategy": {
          "type": "string"
        },
        "invariant_check": {
          "type": "string"
        }
      }
    },
    "EdgeCaseTest": {
      "type": "object",
      "required": [
        "id",
        "requirement_id",
        "kind",
        "description",
        "preconditions",
        "input",
        "expected",
        "assertion_pseudocode"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "requirement_id": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "preconditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "input": {
          "type": "object"
        },
        "expected": {
          "type": "object"
        },
        "assertion_pseudocode": {
          "type": "string"
        }
      }
    },
    "SmokeTest": {
      "type": "object",
      "required": [
        "id",
        "execution_path_id",
        "description",
        "trigger",
        "real_components",
        "mockable",
        "expected_effects"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "execution_path_id": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "trigger": {
          "type": "string"
        },
        "real_components": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mockable": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expected_effects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "Coverage": {
      "type": "object",
      "required": [
        "requirements_covered",
        "properties_covered",
        "paths_covered",
        "gaps"
      ],
      "additionalProperties": false,
      "properties": {
        "requirements_covered": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "properties_covered": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "paths_covered": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "gaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-fox.io/schemas/tasks.v1.json",
  "title": "Tasks v1",
  "description": "Validates tasks.json. Task group 1 must be kind 'tests'; the last group must be kind 'wiring_verification'.",
  "type": "object",
  "required": [
    "spec_id",
    "spec_name",
    "schema_version",
    "test_commands",
    "dependencies",
    "task_groups",
    "traceability"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "spec_id": { "type": "string", "minLength": 1 },
    "spec_name": { "type": "string", "minLength": 1 },
    "schema_version": { "type": "integer", "minimum": 1 },
    "test_commands": { "$ref": "#/$defs/test_commands" },
    "dependencies": {
      "type": "array",
      "items": { "$ref": "#/$defs/task_dependency" }
    },
    "task_groups": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/task_group" }
    },
    "traceability": {
      "type": "array",
      "items": { "$ref": "#/$defs/traceability_entry" }
    }
  },
  "$defs": {
    "test_commands": {
      "type": "object",
      "required": ["spec_tests", "all_tests", "linter"],
      "additionalProperties": false,
      "properties": {
        "spec_tests": { "type": "string" },
        "all_tests": { "type": "string" },
        "linter": { "type": "string" }
      }
    },
    "task_dependency": {
      "type": "object",
      "required": ["depends_on_spec", "from_group", "to_group", "relationship", "sentinel"],
      "additionalProperties": false,
      "properties": {
        "depends_on_spec": { "type": "string" },
        "from_group": { "type": "integer", "minimum": 1 },
        "to_group": { "type": "integer", "minimum": 1 },
        "relationship": { "type": "string" },
        "sentinel": { "type": "boolean" }
      }
    },
    "task_group": {
      "type": "object",
      "required": ["id", "kind", "title", "subtasks", "verification"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "kind": {
          "type": "string",
          "enum": ["tests", "standard", "checkpoint", "wiring_verification"]
        },
        "title": { "type": "string" },
        "subtasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/subtask" }
        },
        "verification": { "$ref": "#/$defs/verification_subtask" }
      }
    },
    "subtask": {
      "type": "object",
      "required": ["id", "title", "details", "test_spec_refs", "requirement_refs", "state", "optional"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "details": { "type": "array", "items": { "type": "string" } },
        "test_spec_refs": { "type": "array", "items": { "type": "string" } },
        "requirement_refs": { "type": "array", "items": { "type": "string" } },
        "state": {
          "type": "string",
          "enum": ["pending", "queued", "in_progress", "done", "pending_reevaluation", "dropped"]
        },
        "optional": { "type": "boolean" }
      }
    },
    "verification_subtask": {
      "type": "object",
      "required": ["id", "checks"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "checks": { "type": "array", "items": { "type": "string" } }
      }
    },
    "traceability_entry": {
      "type": "object",
      "required": ["requirement_id", "test_spec_id", "task_id", "test_path"],
      "additionalProperties": false,
      "properties": {
        "requirement_id": { "type": "string" },
        "test_spec_id": { "type": "string" },
        "task_id": { "type": "string" },
        "test_path": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
      }
    }
  }
}

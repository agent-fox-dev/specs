{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-fox.io/schemas/requirements.v1.json",
  "title": "Requirements v1",
  "description": "Validates requirements.json. Criteria use a discriminated union on ears_pattern.",
  "type": "object",
  "required": [
    "spec_id",
    "spec_name",
    "schema_version",
    "introduction",
    "glossary",
    "requirements",
    "correctness_properties",
    "execution_paths",
    "error_handling"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "spec_id": { "type": "string", "minLength": 1 },
    "spec_name": { "type": "string", "minLength": 1 },
    "schema_version": { "type": "integer", "minimum": 1 },
    "introduction": { "type": "string" },
    "glossary": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "requirements": {
      "type": "array",
      "items": { "$ref": "#/$defs/requirement" }
    },
    "correctness_properties": {
      "type": "array",
      "items": { "$ref": "#/$defs/correctness_property" }
    },
    "execution_paths": {
      "type": "array",
      "items": { "$ref": "#/$defs/execution_path" }
    },
    "error_handling": {
      "type": "array",
      "items": { "$ref": "#/$defs/error_handling_entry" }
    }
  },
  "$defs": {
    "requirement": {
      "type": "object",
      "required": ["id", "title", "user_story", "acceptance_criteria", "edge_cases"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^\\w+-REQ-\\d+$" },
        "title": { "type": "string" },
        "user_story": { "$ref": "#/$defs/user_story" },
        "acceptance_criteria": {
          "type": "array",
          "items": { "$ref": "#/$defs/criterion" }
        },
        "edge_cases": {
          "type": "array",
          "items": { "$ref": "#/$defs/criterion" }
        }
      }
    },
    "user_story": {
      "type": "object",
      "required": ["role", "goal", "benefit"],
      "additionalProperties": false,
      "properties": {
        "role": { "type": "string" },
        "goal": { "type": "string" },
        "benefit": { "type": "string" }
      }
    },
    "criterion": {
      "type": "object",
      "required": ["id", "ears_pattern", "system", "action", "return_contract"],
      "properties": {
        "id": { "type": "string" },
        "ears_pattern": {
          "type": "string",
          "enum": ["ubiquitous", "event_driven", "complex_event", "state_driven", "unwanted", "optional"]
        },
        "system": { "type": "string" },
        "action": { "type": "string" },
        "return_contract": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "trigger": { "type": "string" },
        "condition": { "type": "string" },
        "error_condition": { "type": "string" },
        "state": { "type": "string" },
        "feature": { "type": "string" }
      },
      "oneOf": [
        {
          "title": "ubiquitous",
          "properties": {
            "ears_pattern": { "const": "ubiquitous" },
            "id": {}, "system": {}, "action": {}, "return_contract": {}
          },
          "required": ["id", "ears_pattern", "system", "action", "return_contract"],
          "not": {
            "anyOf": [
              { "required": ["trigger"] },
              { "required": ["condition"] },
              { "required": ["error_condition"] },
              { "required": ["state"] },
              { "required": ["feature"] }
            ]
          }
        },
        {
          "title": "event_driven",
          "properties": {
            "ears_pattern": { "const": "event_driven" },
            "id": {}, "system": {}, "action": {}, "return_contract": {},
            "trigger": { "type": "string", "minLength": 1 }
          },
          "required": ["id", "ears_pattern", "system", "action", "return_contract", "trigger"],
          "not": {
            "anyOf": [
              { "required": ["condition"] },
              { "required": ["error_condition"] },
              { "required": ["state"] },
              { "required": ["feature"] }
            ]
          }
        },
        {
          "title": "complex_event",
          "properties": {
            "ears_pattern": { "const": "complex_event" },
            "id": {}, "system": {}, "action": {}, "return_contract": {},
            "trigger": { "type": "string", "minLength": 1 },
            "condition": { "type": "string", "minLength": 1 }
          },
          "required": ["id", "ears_pattern", "system", "action", "return_contract", "trigger", "condition"],
          "not": {
            "anyOf": [
              { "required": ["error_condition"] },
              { "required": ["state"] },
              { "required": ["feature"] }
            ]
          }
        },
        {
          "title": "state_driven",
          "properties": {
            "ears_pattern": { "const": "state_driven" },
            "id": {}, "system": {}, "action": {}, "return_contract": {},
            "state": { "type": "string", "minLength": 1 }
          },
          "required": ["id", "ears_pattern", "system", "action", "return_contract", "state"],
          "not": {
            "anyOf": [
              { "required": ["trigger"] },
              { "required": ["condition"] },
              { "required": ["error_condition"] },
              { "required": ["feature"] }
            ]
          }
        },
        {
          "title": "unwanted",
          "properties": {
            "ears_pattern": { "const": "unwanted" },
            "id": {}, "system": {}, "action": {}, "return_contract": {},
            "error_condition": { "type": "string", "minLength": 1 }
          },
          "required": ["id", "ears_pattern", "system", "action", "return_contract", "error_condition"],
          "not": {
            "anyOf": [
              { "required": ["trigger"] },
              { "required": ["condition"] },
              { "required": ["state"] },
              { "required": ["feature"] }
            ]
          }
        },
        {
          "title": "optional",
          "properties": {
            "ears_pattern": { "const": "optional" },
            "id": {}, "system": {}, "action": {}, "return_contract": {},
            "feature": { "type": "string", "minLength": 1 }
          },
          "required": ["id", "ears_pattern", "system", "action", "return_contract", "feature"],
          "not": {
            "anyOf": [
              { "required": ["trigger"] },
              { "required": ["condition"] },
              { "required": ["error_condition"] },
              { "required": ["state"] }
            ]
          }
        }
      ]
    },
    "correctness_property": {
      "type": "object",
      "required": ["id", "title", "for_any", "invariant", "validates"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^\\w+-PROP-\\d+$" },
        "title": { "type": "string" },
        "for_any": { "type": "string" },
        "invariant": { "type": "string" },
        "validates": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "execution_path": {
      "type": "object",
      "required": ["id", "title", "steps"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^\\w+-PATH-\\d+$" },
        "title": { "type": "string" },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["actor", "action"],
            "additionalProperties": false,
            "properties": {
              "actor": { "type": "string" },
              "action": { "type": "string" }
            }
          }
        }
      }
    },
    "error_handling_entry": {
      "type": "object",
      "required": ["id", "condition", "behavior", "requirement_id"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^\\w+-ERR-\\d+$" },
        "condition": { "type": "string" },
        "behavior": { "type": "string" },
        "requirement_id": { "type": "string" }
      }
    }
  }
}

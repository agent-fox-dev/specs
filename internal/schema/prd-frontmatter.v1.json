{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-fox.io/schemas/prd-frontmatter.v1.json",
  "title": "PRD Frontmatter v1",
  "description": "Validates the 12 YAML frontmatter fields of prd.md.",
  "type": "object",
  "required": [
    "spec_id",
    "spec_name",
    "title",
    "status",
    "created_at",
    "updated_at",
    "owner",
    "source",
    "supersedes",
    "tags",
    "intent_hash",
    "schema_version"
  ],
  "additionalProperties": false,
  "properties": {
    "spec_id": {
      "type": "string",
      "minLength": 1,
      "description": "Numeric prefix of the spec folder (e.g. '05')."
    },
    "spec_name": {
      "type": "string",
      "minLength": 1,
      "description": "Snake_case slug of the spec folder name."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable title."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "sealed", "superseded", "archived"],
      "description": "Lifecycle state."
    },
    "created_at": {
      "type": "string",
      "description": "ISO 8601 creation timestamp."
    },
    "updated_at": {
      "type": "string",
      "description": "ISO 8601 last-updated timestamp."
    },
    "owner": {
      "type": "string",
      "description": "Author handle."
    },
    "source": {
      "type": "string",
      "description": "URL or reference to the originating issue/discussion."
    },
    "supersedes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of spec_ids this spec supersedes."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Free-form classification tags."
    },
    "intent_hash": {
      "oneOf": [
        { "type": "string", "minLength": 64, "maxLength": 64 },
        { "type": "null" }
      ],
      "description": "SHA-256 hex digest of the normalized Intent section body. Null until draft→active transition."
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version; must be 1 for this schema."
    }
  }
}
